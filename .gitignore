# tracked via `!`-overrides below.
lab/state/*.db
lab/state/*.db-shm
lab/state/*.db-wal
lab/state/*.db-journal
lab/state/local_rekor.jsonl
lab/state/asks.jsonl
lab/state/blessings.jsonl
lab/state/vetoes.jsonl
lab/state/steers.jsonl
lab/state/dev_pending.jsonl
lab/state/pi_actions.jsonl
