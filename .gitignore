# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# Local memory (rebuildable from markdown sources)
memory.db
memory.db-journal
memory.db-wal
memory.db-shm
graph.kuzu/
graph.kuzu-wal

# Credentials (should NEVER be in git)
credentials.json
.env
.env.*
!.env.example

# Backups (size + ephemeral) — keep dir, exclude contents
backup/*/
!backup/.gitkeep

# Control flags (runtime state)
control/PAUSE
control/ABORT
control/dashboard_url.txt
control/alerts.log

# Logs (regenerate per session)
logs/
*.log

# Work-queue runtime state (specific files; keep dir structure)
work_queue/claimed.jsonl
work_queue/pending.jsonl
work_queue/completed/*.jsonl
work_queue/failed/*.jsonl
!work_queue/.gitkeep
!work_queue/**/.gitkeep

# Session-derived state (overwritten each cycle)
state/session_state.md.bak
state/session_start.md
state/session_exit.md
memories/session_brief.md
memories/context_brief.md

# Sub-agent ResultPackets (regenerated per dispatch); keep dir structure
state/results/*.json
!state/results/.gitkeep

# Durable run registry (Sprint 4 B; one {run_id}.json per cycle); keep dir
state/runs/*.json
!state/runs/.gitkeep

# Diagnostics outputs (regenerable)
diagnostics/*.md
!diagnostics/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# ── Runtime state in lab/state/ (J.5 hygiene) ─────────────────────────
