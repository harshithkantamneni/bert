lab/state/bm25_index.json
lab/state/canvas_watcher.state.json
lab/state/approvals/
lab/state/notes/
lab/state/voice_steers/
# Keep tracked source files explicitly
!lab/state/capability_matrix.jsonl
!lab/state/provider_limits_validated.md

# Observability logs (runtime telemetry, regenerated on demand)
state/observability/*.jsonl

# abyssal build artifacts
abyssal/node_modules/
abyssal/v4/node_modules/
abyssal/v4/dist/
abyssal/v4/tsconfig.tsbuildinfo

